{
    // IntelliSense. These mirror CFLAGS_BASE in the Makefile; when that
    // changes, this is what keeps the editor from disagreeing with the build.
    "version": 4,
    "configurations": [
        {
            "name": "Linux",
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/vendor",
                "${workspaceFolder}/tests"
            ],
            "defines": [
                // Without this, pthread_condattr_setclock, clock_gettime and
                // the rest of POSIX 2008 read as undeclared in the editor.
                "_POSIX_C_SOURCE=200809L",
                "IDX_BUILD_DEBUG"
            ]
        }
    ]
}
