# Copy to .env (gitignored) and fill in. Loaded by run.sh.
#
# The endpoint URL usually embeds an API token in its path, which is why .env
# is not committed.

SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_WSS_URL="wss://api.mainnet-beta.solana.com"
# demo
# SOLANA_RPC_URL="https://icy-skilled-layer.solana-mainnet.quiknode.pro/6f45245e054eb893daa03a9ef336c684663ff9bf/"
# SOLANA_WSS_URL="wss://icy-skilled-layer.solana-mainnet.quiknode.pro/6f45245e054eb893daa03a9ef336c684663ff9bf/"

INDEXER_LOG_LEVEL="info"
INDEXER_START_SLOT="0"
INDEXER_END_SLOT="0"
INDEXER_CONCURRENCY="4"

# Blocks buffered between the receive and processing threads. 0 = default (8).
INDEXER_QUEUE_DEPTH="0"

# Subscription shape. commitment: confirmed|finalized. tx_details:
# full|accounts|signatures|none. block_filter: 'all' or a base58 key.
INDEXER_COMMITMENT="confirmed"
INDEXER_TX_DETAILS="full"
INDEXER_BLOCK_FILTER="all"
